
<%- include('../cabecalho.ejs')%>
<main class="container">
        <a href="/medicamento/lst" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Novo medicamento</h2>
            
            <form method="post" >
                <div class="form-group">
                    <label for="nome">Nome</label>
                    <input 
                        type="text" 
                        id="nome" 
                        name="nome" 
                        
                    >
                <div class="form-group">
                    <label for="nome">Fabricante</label>
                    <input 
                        type="text" 
                        id="fabricante" 
                        name="fabricante" 
                        
                    >
                <div class="form-group">
                    <label for="nome">Preço</label>
                    <input 
                        type="number" 
                        id="preco" 
                        name="preco" 
                        
                    >
                <div class="form-group">
                    <label for="nome">É Controlado? (Sim/Não)</label>
                    <input 
                        type="text" 
                        id="controlado" 
                        name="controlado" 
                        
                    >
                <div class="form-group">
                    <label for="nome">Quantidade no Estoque</label>
                    <input 
                        type="number" 
                        id="quantidade" 
                        name="quantidade" 
                        
                    >
                </div>


                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/medicamento/lst" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
<%- include('../rodape.ejs')%>